{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Core user profile data containing preferences and basic stats.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "registryDate": { "type": "string", "format": "date" },
        "birthDate": { "type": "string", "format": "date" },
        "dailyInsight": { "type": "string" },
        "lastInsightTimestamp": { "type": "number" },
        "streak": { "type": "number" },
        "studyTimeTotal": { "type": "number" },
        "diagnosticAccuracy": { "type": "number" },
        "hasCompletedOnboarding": { "type": "boolean" },
        "isPrivateMode": { "type": "boolean" },
        "profileAvatar": { "type": "string", "enum": ["default", "sonographer", "student", "doctor", "nurse"] },
        "companionSkin": { "type": "string", "enum": ["default", "neon", "stealth", "golden", "sonographer", "student"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Progress": {
      "title": "Module/Lesson Progress",
      "description": "Tracks completion and performance for specific lessons.",
      "type": "object",
      "properties": {
        "lessonId": { "type": "string" },
        "moduleId": { "type": "string" },
        "completed": { "type": "boolean" },
        "score": { "type": "number" },
        "lastAccessed": { "type": "string", "format": "date-time" },
        "attempts": { "type": "number" }
      },
      "required": ["lessonId", "completed"]
    },
    "Flashcard": {
      "title": "Spaced Repetition Flashcard",
      "description": "User's personalized SRS data for a concept.",
      "type": "object",
      "properties": {
        "front": { "type": "string" },
        "back": { "type": "string" },
        "moduleId": { "type": "string" },
        "repetition": { "type": "number" },
        "interval": { "type": "number" },
        "easeFactor": { "type": "number" },
        "nextReview": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["front", "back"]
    },
    "ExamResult": {
      "title": "Exam History Entry",
      "description": "Record of a completed full-length or module exam.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "timeTaken": { "type": "number" },
        "moduleBreakdown": { "type": "object" },
        "passed": { "type": "boolean" }
      },
      "required": ["date", "score", "total"]
    },
    "Achievement": {
      "title": "User Achievement",
      "description": "Unlocked badge or milestone.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "unlockedAt": { "type": "string", "format": "date-time" },
        "claimed": { "type": "boolean" }
      },
      "required": ["id", "unlockedAt"]
    },
    "Quest": {
      "title": "User Quest Progress",
      "description": "Status of an active or completed quest.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "currentValue": { "type": "number" },
        "targetValue": { "type": "number" },
        "completed": { "type": "boolean" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "currentValue", "targetValue"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles."
    },
    "/users/{userId}/progress/{lessonId}": {
      "schema": "Progress",
      "description": "Lesson-level progress tracking."
    },
    "/users/{userId}/flashcards/{cardId}": {
      "schema": "Flashcard",
      "description": "Personalized flashcards."
    },
    "/users/{userId}/exams/{examId}": {
      "schema": "ExamResult",
      "description": "Exam history records."
    },
    "/users/{userId}/achievements/{achievementId}": {
      "schema": "Achievement",
      "description": "User achievements."
    },
    "/users/{userId}/quests/{questId}": {
      "schema": "Quest",
      "description": "User quest status."
    }
  }
}
