rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (optional) - Display name
    //   - email: string (required) - User email
    //   - studyGoals: string (optional) - Study goals
    //   - learningStyle: string (optional) - Learning style
    //   - birthDate: string (optional) - Birth date
    //   - birthTime: string (optional) - Birth time
    //   - streak: number (optional) - Study streak
    //   - lastStudyDate: string (optional) - Last study date
    //
    // Collection: examResults
    // Document ID: {auto-id}
    // Fields:
    //   - uid: string (required) - User ID
    //   - score: number (required) - Final score
    //   - total: number (required) - Total questions
    //   - timeTaken: number (required) - Time in seconds
    //   - passed: bool (required) - Pass status
    //   - timestamp: timestamp (required) - Completion time
    //   - moduleBreakdown: map (required) - Topic breakdown
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "latchmanrav@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'email', 'studyGoals', 'learningStyle', 'birthDate', 'birthTime', 'streak', 'lastStudyDate', 'role']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             (!('streak' in data) || data.streak is number) &&
             (!('role' in data) || data.role is string);
    }

    function isValidExamResult(data) {
      return hasRequiredFields(['uid', 'score', 'total', 'timeTaken', 'passed', 'timestamp', 'moduleBreakdown']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.total is number && data.total > 0 &&
             data.timeTaken is number && data.timeTaken >= 0 &&
             data.passed is bool &&
             data.timestamp is timestamp &&
             data.moduleBreakdown is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /examResults/{resultId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidExamResult(request.resource.data);
      allow update: if false; // Exam results should be immutable
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
