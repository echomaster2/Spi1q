rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitives ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // --- PHASE 4: Entity Validators ---

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string 
        && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('streak' in data) || (data.streak is int && data.streak >= 0))
        && (!('studyTimeTotal' in data) || (data.studyTimeTotal is number && data.studyTimeTotal >= 0));
    }

    function isValidProgress(data) {
      return data.lessonId is string && data.lessonId.size() <= 64
        && data.completed is bool
        && (!('score' in data) || (data.score is number && data.score >= 0 && data.score <= 100));
    }

    function isValidFlashcard(data) {
      return data.front is string && data.front.size() <= 1000
        && data.back is string && data.back.size() <= 2000
        && (!('easeFactor' in data) || (data.easeFactor is number && data.easeFactor >= 1.0));
    }

    // --- PHASE 5: Implementation ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming())
        && incoming().createdAt == request.time;
      
      allow update: if isOwner(userId) && isValidUser(incoming())
        && (
          // Action: Profile Update
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'registryDate', 'birthDate', 'profileAvatar', 'companionSkin', 'isPrivateMode', 'hasCompletedOnboarding', 'updatedAt'])) ||
          // Action: Stats Sync
          (incoming().diff(existing()).affectedKeys().hasOnly(['streak', 'studyTimeTotal', 'diagnosticAccuracy', 'dailyInsight', 'lastInsightTimestamp', 'updatedAt']))
        )
        && incoming().uid == existing().uid
        && incoming().updatedAt == request.time;

      // Progress
      match /progress/{lessonId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidProgress(incoming()) && isValidId(lessonId);
      }

      // Flashcards
      match /flashcards/{cardId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidFlashcard(incoming()) && isValidId(cardId);
        allow delete: if isOwner(userId);
      }

      // Exams
      match /exams/{examId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(examId);
      }

      // Achievements & Quests
      match /achievements/{id} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(id);
      }
      
      match /quests/{id} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(id);
      }
    }
  }
}
